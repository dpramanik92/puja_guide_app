{
  "expo": {
    "name": "Puja App",
    "slug": "puja-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#B22222"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.puja.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B22222"
      },
      "package": "com.puja.app"
    },
    "scheme": "puja-app",
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
